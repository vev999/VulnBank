# VulnBank — przykładowe zmienne środowiskowe
# Skopiuj do .env przed uruchomieniem (opcjonalne — docker-compose.yml ma wartości domyślne)

# Flask
FLASK_DEBUG=true
FLASK_ENV=development
SECRET_KEY=supersecretkey

# Baza danych
DATABASE_URL=postgresql://vulnbank:vulnbank@db/vulnbank
POSTGRES_DB=vulnbank
POSTGRES_USER=vulnbank
POSTGRES_PASSWORD=vulnbank

# Redis (celowo bez hasła — podatność A02)
REDIS_URL=redis://redis:6379

# CTF Flags
FLAG_A02=PWR{debug_config_exposed}

# Klucz wewnętrzny API
INTERNAL_API_KEY=dev-internal-key-do-not-share

# Uwaga: SECRET_KEY jest wspólny dla bank JWT i CTF JWT.
# Bank JWT ma claim: is_admin (bool)
# CTF JWT ma claim:  ctf_player: true, nickname (string)
# Tokeny są rozróżniane po claimach, nie po sekrecie.
